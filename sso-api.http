// SSO API - File Management (ownCloud)
// Chọn môi trường (comment/bỏ comment dòng tương ứng):
# @base_url = http://localhost:9898
@base_url = https://file.dannsolutions.com
@client_id = dann_hrm
@client_secret = abc123xyz

// =============================================================
// 📋 CÁCH THÊM SSO CLIENT MỚI
// =============================================================
//
// SSO clients được lưu trong config/config.php dưới key "sso_clients".
// Mỗi entry là: "client_id" => "client_secret"
//
// Thêm client mới qua occ (SSH vào server):
//
//   # Xem danh sách client hiện tại:
//   sudo -u www-data php7.4 /var/www/html/owncloud/occ config:system:get sso_clients
//
//   # Thêm/cập nhật toàn bộ danh sách (JSON):
//   sudo -u www-data php7.4 /var/www/html/owncloud/occ config:system:set sso_clients \
//     --type=json \
//     --value='{"dann_hrm":"abc123xyz","app2":"secret2","app3":"secret3"}'
//
// Lưu ý:
//   - client_id: định danh ứng dụng bên ngoài (không trùng nhau)
//   - client_secret: mật khẩu chia sẻ, nên dùng chuỗi ngẫu nhiên dài ≥ 32 ký tự
//   - Sinh secret ngẫu nhiên: openssl rand -hex 32
//   - User phải có email được set trong ownCloud (occ user:modify <uid> email <email>)
//
// =============================================================
// ✅ THÀNH CÔNG - Đăng nhập admin
// =============================================================

### SSO Login - admin@dannsolutions.com
// Trả về HTTP 303 → redirect về trang Files (đăng nhập thành công)
// @no-redirect
GET {{base_url}}/api/sso/login?client_id={{client_id}}&client_secret={{client_secret}}&email=admin@dannsolutions.com

###

// =============================================================
// ❌ LỖI - Client không hợp lệ
// =============================================================

### Client ID sai → 401 Invalid client credentials
GET {{base_url}}/api/sso/login?client_id=wrong_client&client_secret={{client_secret}}&email=admin@dannsolutions.com

###

### Client Secret sai → 401 Invalid client credentials
GET {{base_url}}/api/sso/login?client_id={{client_id}}&client_secret=wrong_secret&email=admin@dannsolutions.com

###

// =============================================================
// ❌ LỖI - User không tồn tại
// =============================================================

### Email không tồn tại → 404 User not found
GET {{base_url}}/api/sso/login?client_id={{client_id}}&client_secret={{client_secret}}&email=khongtontai@dannsolutions.com

###

### Email chưa được set trong ownCloud → 404 User not found
// Tạo user rồi set email: occ user:modify <uid> email <email>
GET {{base_url}}/api/sso/login?client_id={{client_id}}&client_secret={{client_secret}}&email=user1@gmail.com

###

// =============================================================
// ❌ LỖI - Thiếu tham số
// =============================================================

### Thiếu email → 400 Missing required parameters
GET {{base_url}}/api/sso/login?client_id={{client_id}}&client_secret={{client_secret}}

###

### Thiếu client_secret → 400 Missing required parameters
GET {{base_url}}/api/sso/login?client_id={{client_id}}&email=admin@dannsolutions.com

###

### Thiếu client_id → 400 Missing required parameters
GET {{base_url}}/api/sso/login?client_secret={{client_secret}}&email=admin@dannsolutions.com

###

### Không có tham số nào → 400 Missing required parameters
GET {{base_url}}/api/sso/login

###
